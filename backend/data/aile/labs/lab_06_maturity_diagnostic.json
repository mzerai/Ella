{
    "lab_id": "06_maturity_diagnostic",
    "title": {
        "fr": "Diagnostic de Maturité IA",
        "en": "AI Maturity Diagnostic"
    },
    "description": {
        "fr": "Évaluez la maturité IA de votre organisation sur 7 dimensions. ELLA analyse vos réponses et génère un diagnostic personnalisé avec plan d'action.",
        "en": "Assess your organization's AI maturity across 7 dimensions. ELLA analyzes your answers and generates a personalized diagnostic with action plan."
    },
    "concept": {
        "fr": "Ce diagnostic s'inspire des modèles de maturité IA de référence (Gartner, NIST, ISO 42001). Il évalue votre organisation sur 7 dimensions clés et vous positionne sur 5 niveaux de maturité : Awareness, Active, Operational, Systemic, Transformational. Le résultat est un rapport structuré que vous pouvez présenter à votre comité de direction.",
        "en": "This diagnostic draws on reference AI maturity models (Gartner, NIST, ISO 42001). It evaluates your organization across 7 key dimensions and positions you on 5 maturity levels: Awareness, Active, Operational, Systemic, Transformational. The result is a structured report you can present to your board."
    },
    "lab_type": "maturity_diagnostic",
    "maturity_levels": [
        {
            "level": 1,
            "name": "Awareness",
            "name_fr": "Sensibilisation",
            "description_fr": "L'entreprise parle d'IA, mais les usages restent flous. Intérêt fort, peu d'exécution.",
            "description_en": "The company talks about AI, but uses remain unclear. Strong interest, little execution.",
            "score_range": [1.0, 1.9]
        },
        {
            "level": 2,
            "name": "Active",
            "name_fr": "Expérimentation",
            "description_fr": "Des expérimentations existent dans quelques équipes. Pilotes isolés.",
            "description_en": "Experiments exist in a few teams. Isolated pilots.",
            "score_range": [2.0, 2.9]
        },
        {
            "level": 3,
            "name": "Operational",
            "name_fr": "Opérationnel",
            "description_fr": "Des cas d'usage IA sont en production. Valeur mesurée sur certains processus.",
            "description_en": "AI use cases are in production. Value measured on some processes.",
            "score_range": [3.0, 3.9]
        },
        {
            "level": 4,
            "name": "Systemic",
            "name_fr": "Systémique",
            "description_fr": "L'IA est structurée à l'échelle de l'entreprise. Plateformes, gouvernance et portefeuille IA.",
            "description_en": "AI is structured enterprise-wide. Platforms, governance and AI portfolio.",
            "score_range": [4.0, 4.6]
        },
        {
            "level": 5,
            "name": "Transformational",
            "name_fr": "Transformationnel",
            "description_fr": "L'IA transforme le modèle économique. Avantage concurrentiel fondé sur l'IA.",
            "description_en": "AI transforms the business model. Competitive advantage built on AI.",
            "score_range": [4.7, 5.0]
        }
    ],
    "prudence_rule": {
        "description_fr": "Une entreprise ne peut pas être classée au niveau 4 ou 5 si l'une de ces dimensions est inférieure à 3 : Données, Gouvernance, Technologie, Cas d'usage.",
        "description_en": "A company cannot be rated level 4 or 5 if any of these dimensions is below 3: Data, Governance, Technology, Use cases.",
        "blocking_dimensions": ["data", "governance", "technology", "use_cases"]
    },
    "company_profile": {
        "title": {
            "fr": "Profil de votre organisation",
            "en": "Your organization profile"
        },
        "fields": [
